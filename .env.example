# SUPABASE CONNECTION (Required)
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key-here
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key-here

# DATABASE CONNECTION (Direct PostgreSQL for migrations/advanced scripts)
DATABASE_URL=postgresql://postgres:[password]@db.your-project.supabase.co:5432/postgres

# AUTH (Required for production security)
JWT_SECRET=your-32-character-secret-key-here

# RESEND EMAIL CONFIGURATION (Required for automated emails)
RESEND_API_KEY=re_your_resend_api_key_here
SMTP_FROM="PayoutPower <onboarding@resend.dev>"

# APPLICATION URL (Required for email links)
NEXT_PUBLIC_APP_URL=https://your-app-domain.com

# ENVIRONMENT (Required to ensure secure cookies only in production)
NODE_ENV=production
