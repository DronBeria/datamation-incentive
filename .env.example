# ═══════════════════════════════════════════════════
# PayoutPower (IncenSys) — Environment Configuration
# ═══════════════════════════════════════════════════
# Copy this file to .env and fill in all required values

# SUPABASE CONNECTION (Required)
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key-here
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key-here

# DATABASE CONNECTION (Direct PostgreSQL for migrations/advanced scripts)
DATABASE_URL=postgresql://postgres:[password]@db.your-project.supabase.co:6543/postgres?prepare_threshold=0

# AUTH (Required for production security — minimum 32 characters)
JWT_SECRET=your-32-character-secret-key-here

# SMTP EMAIL CONFIGURATION (Required for automated emails)
SMTP_HOST=smtp.gmail.com
SMTP_PORT=465
SMTP_USER=your-email@gmail.com
SMTP_PASS="your-app-password"
SMTP_FROM="PayoutPower <your-email@gmail.com>"

# RESEND EMAIL (Alternative to SMTP — only one is needed)
# RESEND_API_KEY=re_your_resend_api_key_here

# APPLICATION URL (Required for email links and CORS)
NEXT_PUBLIC_APP_URL=https://your-app-domain.com

# ENVIRONMENT
NODE_ENV=production

# ─── Security & API Keys ───

# Cron Job Secret (Required in production for /api/cron/* endpoints)
CRON_SECRET=your-cron-secret-here

# External API Key (Optional — for third-party integrations)
# EXTERNAL_API_KEY=your-external-api-key-here

# Payment Integration
# STITCH_API_KEY=your-stitch-api-key-here
